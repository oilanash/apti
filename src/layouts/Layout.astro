---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="ce">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>

		<!-- SEO Basics -->
		<meta name="description" content="«Хьайбахахь язйина байташ» — Апти Бисултанов. Мемориальный цифровой проект, посвященный трагедии Хайбаха 1944 года. Текст поэмы на чеченском языке." />
		<meta name="keywords" content="Хьайбаха, Апти Бисултанов, чеченская поэзия, Хайбах 1944, депортация, поэма, нохчийн мотт" />
		<meta name="author" content="oilanash" />

		<!-- Open Graph / Facebook / WhatsApp -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://ваш_логин.github.io/khaibakh/" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content="«Хьайбахахь язйина байташ» — Апти Бисултанов. Мемориальный цифровой проект." />
		<meta property="og:image" content="/Apti.png" />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content="«Хьайбахахь язйина байташ» — цифровой мемориал." />
		<meta name="twitter:image" content="/Apti.png" />
		
		<!-- Canonical -->
		<link rel="canonical" href="https://ваш_логин.github.io/khaibakh/" />
	</head>
	<body class="bg-background text-foreground antialiased overflow-x-hidden selection:bg-foreground selection:text-background">
		<!-- Кастомный курсор (Mix Blend Mode) -->
		<div id="cursor" class="fixed top-0 left-0 w-8 h-8 rounded-full bg-white pointer-events-none z-[9999] mix-blend-difference hidden md:block" style="transform: translate(-50%, -50%);"></div>
		
		<slot />

		<script>
      import Lenis from '@studio-freight/lenis';
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      // Глобальный тяжелый скроллLenis
      const lenis = new Lenis({
        duration: 2.5, // Очень вязкий, тяжелый скролл
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        smoothWheel: true,
        wheelMultiplier: 0.8,
      });

      function raf(time: number) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }
      requestAnimationFrame(raf);

      // Обновляем ScrollTrigger при скролле
      lenis.on('scroll', ScrollTrigger.update);

      gsap.ticker.add((time) => {
        lenis.raf(time * 1000);
      });
      gsap.ticker.lagSmoothing(0);

      // Кастомный курсор
      const cursor = document.getElementById('cursor');
      if (cursor) {
        document.addEventListener('mousemove', (e) => {
          gsap.to(cursor, {
            x: e.clientX,
            y: e.clientY,
            duration: 0.1,
            ease: "power2.out"
          });
        });
      }
		</script>
	</body>
</html>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@100..900&display=swap');

  :root {
    --scroll-velocity: 0;
  }

	body {
		font-family: 'Inter', sans-serif;
    /* Убираем дефолтный курсор для красоты */
    cursor: none; 
	}
  
  a, button {
    cursor: none; /* Кастомный курсор заменяет всё */
  }

  /* Динамическое изменение насыщенности шрифта через CSS Variable (меняется через JS позже) */
  .variable-text {
    font-weight: calc(300 + var(--scroll-velocity) * 50);
  }
</style>
